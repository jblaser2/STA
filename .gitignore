# Ignore large microscopy / data files

*.mrc
*.mrcs
*.map

# RELION / cryo-EM metadata

*.star

# HDF5 data formats

*.hdf
*.h5
*.hdf5

# Optional: other large binary data formats

*.bin
*.dat

# Python pickles (model weights, checkpoints — can be hundreds of MB)
*.pkl

# MATLAB binary data files (can be large)
*.mat

# Ignore compressed archives (often large)

*.zip
*.tar
*.gz
*.bz2
*.7z

# PyTom / EM binary volumes (large)

*.em

# Claude Code machine-specific settings (keep shared settings.json committed)

.claude/settings.local.json

# emClarity runtime artifacts (written to cwd when run from the repo root)

logFile/
emClarity_checkInstall.txt

# ignore codegraph
.codegraph

# MATLAB autosave and backup files
*.m~
*.asv
*.bak.m
*.bak2.m
*.m.bak

# HPC job output logs
*.log
*.err

# STOPGAP compiled MATLAB MCR binaries (platform-specific ELF executables; recompile on target)
packages/STOPGAP/exec/lib*/sg_toolbox
packages/STOPGAP/exec/lib*/stopgap
packages/STOPGAP/exec/lib*/stopgap_parser
packages/STOPGAP/exec/lib*/stopgap_watcher

# eman2 settings files
.eman2settings.json
trash/
trash/
.eman2log.txt
