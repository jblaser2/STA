# Ignore large microscopy / data files

*.mrc
*.mrcs
*.map

# RELION / cryo-EM metadata

*.star

# HDF5 data formats

*.hdf
*.h5
*.hdf5

# Optional: other large binary data formats

*.bin
*.dat

# Ignore compressed archives (often large)

*.zip
*.tar
*.gz
*.bz2
*.7z

# PyTom / EM binary volumes (large)

*.em

# Claude Code machine-specific settings (keep shared settings.json committed)

.claude/settings.local.json

# emClarity runtime artifacts (written to cwd when run from the repo root)

logFile/
emClarity_checkInstall.txt

# ignore codegraph
.codegraph
